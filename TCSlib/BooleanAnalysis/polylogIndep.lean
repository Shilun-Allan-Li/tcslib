/-
Definition of a Boolean circuit with n inputs.
-/
inductive Circuit (n : ℕ)
| input : Fin n → Circuit n
| const : Bool → Circuit n
| not : Circuit n → Circuit n
| and : List (Circuit n) → Circuit n
| or : List (Circuit n) → Circuit n

/-
Size of a Boolean circuit.
-/
def Circuit.size {n : ℕ} : Circuit n → ℕ
| input _ => 1
| const _ => 1
| not c => c.size + 1
| and cs => (cs.map size).sum + 1
| or cs => (cs.map size).sum + 1
