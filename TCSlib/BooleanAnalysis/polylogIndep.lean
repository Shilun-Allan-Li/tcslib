simp +zetaDelta at *; (
rename_i c hc;
induction' cs with cs ih generalizing c <;> simp_all +decide [ List.length ];
grind); (
rename_i c hc;
induction' cs with cs ih generalizing c <;> simp_all +decide [ List.length ];
grind)

/-
Depth of a Boolean circuit.
-/
def Circuit.depth {n : ℕ} : Circuit n → ℕ
| input _ => 0
| const _ => 0
| not c => c.depth + 1
| and cs => (cs.map depth).maximum.getD 0 + 1
| or cs => (cs.map depth).maximum.getD 0 + 1
