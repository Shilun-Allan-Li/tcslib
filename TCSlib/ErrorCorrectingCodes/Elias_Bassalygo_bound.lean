/-
Lemma 3.1: Suppose v_1, ..., v_m are unit vectors in R^n such that <v_i, v_j> ≤ -ε for all i ≠ j. Then m ≤ 1 + 1/ε.
-/


theorem lemma_3_1 {m n : ℕ} {ε : ℝ} (hε : 0 < ε)
  (v : Fin m → EuclideanSpace ℝ (Fin n))
  (h_unit : ∀ i, ‖v i‖ = 1)
  (h_dot : ∀ i j, i ≠ j → inner ℝ (v i) (v j) ≤ -ε) :
  (m : ℝ) ≤ 1 + 1 / ε := by
    -- Consider the norm of the sum of these vectors:
    have h_norm : ‖∑ i, v i‖^2 = ∑ i, ∑ j, ⟪v i, v j⟫_ℝ := by
      rw [ ← real_inner_self_eq_norm_sq ];
      simp +decide only [inner_sum, sum_inner];
      exact Finset.sum_comm;
    -- Since $<v_i, v_j> \leq -ε$ for all $i \neq j$, we have $\sum_{i \neq j} <v_i, v_j> \leq -ε \cdot m(m-1)$.
    have h_sum_dot : ∑ i, ∑ j ∈ Finset.univ.erase i, ⟪v i, v j⟫_ℝ ≤ -ε * m * (m - 1) := by
      refine' le_trans ( Finset.sum_le_sum fun i hi => Finset.sum_le_sum fun j hj => h_dot i j <| by aesop ) _ ; norm_num ; ring_nf ; norm_num [ hε.ne' ] ;
      cases m <;> norm_num ; nlinarith;
    simp_all +decide [ inner_self_eq_norm_sq_to_K ];
    nlinarith [ inv_pos.2 hε, mul_inv_cancel₀ hε.ne', sq ( m : ℝ ) ]


def min_distance (C : Code n α) : ℕ :=
  if h : C.card < 2 then 0 else
  (C.product C).filter (fun x ↦ x.1 ≠ x.2) |>.image (fun x ↦ hammingDist x.1 x.2) |>.min' (by
  obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.1 ( by linarith ) ; exact ⟨ _, Finset.mem_image.2 ⟨ ( x, y ), Finset.mem_filter.2 ⟨ Finset.mem_product.2 ⟨ hx, hy ⟩, hxy ⟩, rfl ⟩ ⟩)

def is_distance_at_least (C : Code n α) (d : ℕ) : Prop :=
  ∀ c1 ∈ C, ∀ c2 ∈ C, c1 ≠ c2 → hammingDist c1 c2 ≥ d

def is_constant_weight (C : Code n α) (w : ℕ) : Prop :=
  ∀ c ∈ C, weight c = w

def is_bounded_weight (C : Code n α) (w : ℕ) : Prop :=
  ∀ c ∈ C, weight c ≤ w

/-
A_q(n, d) is the maximum size of a code of length n and minimum distance d.
-/
noncomputable def A_q (n d : ℕ) (α : Type*) [Fintype α] [DecidableEq α] : ℕ :=
  (Finset.univ : Finset (Code n α)).filter (fun C ↦ is_distance_at_least C d) |>.image Finset.card |>.max' (by
  -- The empty set is a code with minimum distance d, so its cardinality is 0.
  use 0
  simp [is_distance_at_least])

/-
A_q(n, d, w) is the maximum size of a constant weight code of length n, minimum distance d, and weight w.
-/
noncomputable def A_q_w (n d w : ℕ) (α : Type*) [Fintype α] [DecidableEq α] [Field α] : ℕ :=
  (Finset.univ : Finset (Code n α)).filter (fun C ↦ is_distance_at_least C d ∧ is_constant_weight C w) |>.image Finset.card |>.max' (by
  use 0
  simp [is_distance_at_least, is_constant_weight])

/-
A0_q(n, d, w) is the maximum size of a code of length n, minimum distance d, and weight at most w.
-/
noncomputable def A0_q_w (n d w : ℕ) (α : Type*) [Fintype α] [DecidableEq α] [Field α] : ℕ :=
  (Finset.univ : Finset (Code n α)).filter (fun C ↦ is_distance_at_least C d ∧ is_bounded_weight C w) |>.image Finset.card |>.max' (by
  use 0
  simp [is_distance_at_least, is_bounded_weight])

